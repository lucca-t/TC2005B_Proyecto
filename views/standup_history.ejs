<%- include('includes/_header') %>

<section class="section">
    <div class="container">
        <div class="level mb-4">
            <div class="level-left">
                <div>
                    <h1 class="title">Activity History</h1>
                    <h2 class="subtitle">Your daily standup records</h2>
                </div>
            </div>
            <div class="level-right">
                <a href="/daily_standup" class="button is-primary"><strong>+ New Standup</strong></a>
            </div>
        </div>
    </div>
</section>

<section class="section" style="padding-top: 0;">
    <div class="container">

        <% if (typeof error !== 'undefined' && error.length > 0) { %>
            <div class="notification is-danger is-light">
                <button class="delete" onclick="this.parentElement.remove()"></button>
                <%= error %>
            </div>
        <% } %>
        
        <div class="box">
            <% if (standups.length === 0) { %>
                <div class="notification is-warning is-light">
                    No records found.
                </div>
            <% } else { %>
                <div class="table-container">
                    <table class="table is-fullwidth is-striped is-hoverable">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>What did you do?</th>
                                <th>What will you do tomorrow?</th>
                                <th>Blockers</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% standups.forEach(standup => { %>
                                <tr>
                                    <td><%= standup.date.toISOString().split('T')[0] %></td>
                                    <td><%= standup.did_today %></td>
                                    <td><%= standup.do_tomorrow %></td>
                                    <td><%= standup.blockers || '-' %></td>
                                    <td>
                                        <div class="buttons">
                                            <a href="/daily_standup/report/<%= standup.standup_id %>" class="button is-small is-dark">AI Report</a>
                                            <a href="/daily_standup/edit/<%= standup.standup_id %>" class="button is-small is-light">Edit</a>
                                            <form action="/daily_standup/history/<%= standup.standup_id %>" method="POST">    
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <button type="submit"
                                                        class="button is-small is-light"
                                                        onclick="return confirm('Are you sure you want to delete this record?');">Delete
                                                </button>
                                            </form>    
                                        </div>    
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</section>

<%- include('includes/_footer') %>
