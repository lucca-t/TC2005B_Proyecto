<%- include('includes/_header') %>

<section class="section">
  <div class="container">
    <div class="level">
      <div class="level-left">
        <h1 class="title">
          <% if (typeof user !== 'undefined' && user) { %>
            Report History for <%= user.full_name || user.email %>
          <% } else { %>
            Report History
          <% } %>
        </h1>
      </div>
      <div class="level-right">
        <div class="buttons">
          <% if (typeof user !== 'undefined' && user && (typeof role === 'undefined' || role === 'Administrador' || role === 'Lead Member')) { %>
          <a href="/users/report/<%= user.user_id %>" class="button is-dark">
            <span class="icon"><i class="fas fa-file-alt"></i></span>
            <span>Generate New Report</span>
          </a>
          <% } %>
          <a href="/users/list" class="button is-light">← Back</a>
        </div>
      </div>
    </div>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="notification is-success is-light" id="successNotification">
      <button class="delete" onclick="this.parentElement.remove()"></button>
      <strong><%= success %></strong>
    </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="notification is-danger is-light">
      <button class="delete" onclick="this.parentElement.remove()"></button>
      <strong><%= error %></strong>
    </div>
    <% } %>

    <div class="box">
      <h2 class="subtitle">Saved AI Reports</h2>

      <% if (reports && reports.length > 0) { %>
      <table class="table is-fullwidth is-striped is-hoverable">
        <thead>
          <tr>
            <th>Period</th>
            <th>Generated On</th>
            <th class="has-text-right">Action</th>
          </tr>
        </thead>
        <tbody>
          <% reports.forEach((report) => { %>
          <tr>
            <td>
              <%= new Date(report.date_beginning).toISOString().split('T')[0] %>
              &mdash;
              <%= new Date(report.date_end).toISOString().split('T')[0] %>
            </td>
            <td>
              <%= new Date(report.date_generated).toLocaleString() %>
            </td>
            <td class="has-text-right">
              <a href="/users/report/<%= user.user_id %>?reportId=<%= report.report_id %>" class="button is-small is-light">
                Open
              </a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } else { %>
      <p class="has-text-grey">No saved reports yet for this user.</p>
      <% } %>
    </div>

    <div class="box">
      <h2 class="subtitle">Daily Standup History</h2>

      <% if (typeof standups !== 'undefined' && standups && standups.length > 0) { %>
      <div class="table-container">
        <table class="table is-fullwidth is-striped is-hoverable">
          <thead>
            <tr>
              <th>Date</th>
              <th>What did you do?</th>
              <th>What will you do tomorrow?</th>
              <th>Blockers</th>
              <% if (typeof role !== 'undefined' && (role === 'Administrador' || role === 'Lead Member')) { %>
              <th>Actions</th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% standups.forEach((standup) => { %>
            <tr>
              <td><%= new Date(standup.date).toISOString().split('T')[0] %></td>
              <td><%= standup.did_today %></td>
              <td><%= standup.do_tomorrow %></td>
              <td><%= standup.blockers || '—' %></td>
              <% if (typeof role !== 'undefined' && (role === 'Administrador' || role === 'Lead Member')) { %>
              <td>
                <form action="/users/report/<%= user.user_id %>/standup/<%= standup.standup_id %>/delete" method="POST" style="display:inline;">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="button is-small is-light"
                    onclick="return confirm('Are you sure you want to delete this standup?');">
                    Delete
                  </button>
                </form>
              </td>
              <% } %>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <p class="has-text-grey">No daily standups registered for this user.</p>
      <% } %>
    </div>
  </div>
</section>

<%- include('includes/_footer') %>

