<%- include('includes/_header') %>

<section class="section">
    <div class="container">
        <div class="level mb-4">
            <div class="level-left">
                <h1 class="title">Team Management</h1>
            </div>
            <div class="level-right">
                <a href="/teams/list" class="button is-light"><strong>← Back</strong></a>
            </div>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="notification is-danger is-light mb-4">
                <button class="delete" onclick="this.parentElement.remove()"></button>
                <strong><%= error %></strong>
            </div>
        <% } %>

        <div class="columns">
            <!-- LEFT: TEAM INFO -->
            <div class="column is-5">
                <div class="box">
                    <h2 class="subtitle has-text-centered mb-5">Create New Team</h2>

                    <form action="/teams/add" method="POST" id="teamForm">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                        <div class="field">
                            <label class="label">Team Name</label>
                            <div class="control">
                                <input class="input" type="text" name="teamName" id="teamNameInput" placeholder="Enter team name" maxlength="100" required>
                            </div>
                            <p class="help" id="charCounter">0/100</p>
                        </div>

                        <!-- MEMBER SELECTION (hidden inputs) -->
                        <div id="memberInputs"></div>

                        <div class="field mt-5">
                            <div class="control">
                                <button type="submit" class="button is-primary is-fullwidth">
                                    <strong>Create Team</strong>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- RIGHT: MEMBER SELECTOR -->
            <div class="column is-7">
                <div class="box">
                    <h2 class="subtitle mb-4">Quick Assign Members</h2>

                    <!-- SEARCH -->
                    <div class="field mb-4">
                        <div class="control">
                            <input id="searchInput" class="input" type="text" placeholder="Search user by name or email...">
                        </div>
                    </div>

                    <!-- TABLE -->
                    <div style="max-height: 400px; overflow-y: auto; border: 1px solid #dbdbdb; border-radius: 4px;">
                        <table class="table is-fullwidth is-striped" style="margin-bottom: 0;">
                            <thead style="position: sticky; top: 0; background-color: #f5f5f5;">
                                <tr>
                                    <th style="width: 50px;">Select</th>
                                    <th>User</th>
                                </tr>
                            </thead>
                            <tbody id="userTable">
                                <% if (typeof users !== 'undefined' && users.length > 0) { %>
                                    <% users.forEach(user => { %>
                                        <tr class="user-row" data-search="<%= (user.full_name + ' ' + user.email).toLowerCase() %>">
                                            <td style="text-align: center; vertical-align: middle;">
                                                <input type="checkbox" class="user-checkbox" value="<%= user.user_id %>">
                                            </td>
                                            <td>
                                                <div>
                                                    <strong><%= user.full_name %></strong>
                                                </div>
                                                <p class="has-text-grey is-size-7"><%= user.email %></p>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="2" class="has-text-centered has-text-grey py-5">
                                            No users available.
                                        </td>
                                    </tr>
                                <% } %>
                                <tr id="noResultsRow" style="display: none;">
                                    <td colspan="2" class="has-text-centered has-text-grey py-5">
                                        Users not found.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <p class="has-text-grey mt-3 is-size-7">
                        ✓ Check members to include them in the team
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- JS -->
<script>
    // SEARCH FILTER
    const searchInput = document.getElementById("searchInput");
    const rows = document.querySelectorAll("#userTable tr.user-row");
    const noResultsRow = document.getElementById("noResultsRow");

    function updateSearchResults() {
        const value = searchInput.value.toLowerCase();
        let visibleCount = 0;

        rows.forEach(row => {
            const searchData = row.getAttribute("data-search") || "";
            const show = searchData.includes(value);
            row.style.display = show ? "" : "none";
            if (show) visibleCount += 1;
        });

        if (visibleCount === 0 && rows.length > 0) {
            noResultsRow.style.display = "";
        } else {
            noResultsRow.style.display = "none";
        }
    }

    searchInput.addEventListener("keyup", updateSearchResults);

    // CREATE HIDDEN INPUTS FOR SELECTED MEMBERS
    function updateMemberInputs() {
        const memberInputs = document.getElementById("memberInputs");
        memberInputs.innerHTML = "";

        document.querySelectorAll(".user-checkbox:checked").forEach(checkbox => {
            const input = document.createElement("input");
            input.type = "hidden";
            input.name = "members";
            input.value = checkbox.value;
            memberInputs.appendChild(input);
        });

        const selectedCount = document.querySelectorAll(".user-checkbox:checked").length;
        console.log("[TeamAdd] Selected members:", selectedCount);
    }

    // UPDATE WHEN CHECKBOX IS CHANGED
    document.querySelectorAll(".user-checkbox").forEach(checkbox => {
        checkbox.addEventListener("change", updateMemberInputs);
    });

    // UPDATE BEFORE FORM SUBMISSION
    document.getElementById("teamForm").addEventListener("submit", function(e) {
        console.log("[TeamAdd] Form submitting...");
        updateMemberInputs();
        const selected = Array.from(document.querySelectorAll(".user-checkbox:checked")).map(c => c.value);
        console.log("[TeamAdd] Final members list:", selected);
    });

    // CHARACTER COUNTER FOR TEAM NAME
    const teamNameInput = document.getElementById("teamNameInput");
    const charCounter = document.getElementById("charCounter");

    function updateCharCounter() {
        const current = teamNameInput.value.length;
        charCounter.textContent = current + "/100";
    }

    teamNameInput.addEventListener("input", updateCharCounter);
    updateCharCounter();
</script>

<%- include('includes/_footer') %>