<%- include('includes/_header') %>

<%
    const safeFormData =
        (typeof formData !== 'undefined' && formData) ? formData : {};
%>

<section class="section">
    <div class="container">
        <div class="level mb-4">
            <div class="level-left">
                <h1 class="title">User Management</h1>
            </div>
            <div class="level-right">
                <a href="/users/list" class="button is-light"><strong>← Back</strong></a>
            </div>
        </div>

    <div class="columns is-centered">
        <div class="column is-6">
            <div class="box">
                <h2 class="subtitle has-text-centered mb-5">Add New User</h2>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="notification is-danger is-light mt-4">
                        <%= error %>
                    </div>
                <% } %>

                <form action="/users/add" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <div class="field">
                        <label class="label">Email</label>
                        <div class="control">
                            <input class="input" type="email" name="email" data-live-email-validate="true" maxlength="50" value="<%= safeFormData.email ? safeFormData.email : '' %>" placeholder="email@example.com" autocomplete="email" pattern="^[^\s@]+@[^\s@]+\.[^\s@]+$" required>
                        </div>
                    </div>

                    <div class="field">
                        <label class="label">Full Name</label>
                        <div class="control">
                            <input class="input" type="text" name="full_name" maxlength="150" value="<%= safeFormData.full_name ? safeFormData.full_name : '' %>" placeholder="John Appleseed" required>
                        </div>
                    </div>

                    <div class="field">
                        <label class="label">Password</label>
                        <div class="control">
                            <input class="input" type="text" name="password" placeholder="Use a secure password" required>
                        </div>
                    </div>

                    <div class="field">
                        <label class="label">Slack Handle</label>
                        <div class="control">
                            <input class="input" type="text" name="slack_handle" maxlength="100" value="<%= safeFormData.slack_handle ? safeFormData.slack_handle : '' %>" placeholder="membername or @membername" required>
                        </div>
                        <p class="help">You can enter it with or without @. Example: membername or @membername.</p>
                    </div>

                    <div class="field">
                        <label class="label">Slack ID</label>
                        <div class="control">
                            <input class="input" type="text" name="slack_id" maxlength="50" value="<%= safeFormData.slack_id ? safeFormData.slack_id : '' %>" placeholder="U012AB345CD" required>
                        </div>
                    </div>

                    <div class="field mt-5">
                        <div class="control">
                            <button type="submit" class="button is-primary is-fullwidth">
                                <strong>Create User</strong>
                            </button>
                        </div>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

</section>

<script src="/js/user-email-validation.js" defer></script>

<%- include('includes/_footer') %>