<%- include('includes/_header') %>

<section class="section">
  <div class="container">
    <div class="level mb-4">
      <div class="level-left">
        <div>
          <h1 class="title">Team Activity History</h1>
          <h2 class="subtitle">Review standups from members of your team</h2>
        </div>
      </div>
      <div class="level-right">
        <a href="/daily_standup/history" class="button is-light">
          <strong>My History</strong>
        </a>
      </div>
    </div>
  </div>
</section>

<section class="section" style="padding-top: 0;">
  <div class="container">
    <div id="teamHistoryError" class="notification is-danger is-light <%= (typeof error !== 'undefined' && error.length > 0) ? '' : 'is-hidden' %>">
      <button class="delete" onclick="this.parentElement.classList.add('is-hidden')"></button>
      <span id="teamHistoryErrorText"><%= (typeof error !== 'undefined' && error.length > 0) ? error : '' %></span>
    </div>

    <div class="box mb-5">
      <form id="teamHistoryFiltersForm" method="GET" action="/daily_standup/history/team">
        <div class="columns is-multiline is-vcentered">

          <div class="column is-4">
            <div class="field">
              <label class="label">Team</label>
              <div class="control">
                <div class="select is-fullwidth">
                  <select id="teamHistoryTeamFilter" name="team_id">
                    <% if (typeof teams !== 'undefined' && teams.length > 0) { %>
                      <% teams.forEach((teamOption) => { %>
                        <option value="<%= teamOption.id %>" <%= String(teamOption.id) === String(selectedTeamId || '') ? 'selected' : '' %>><%= teamOption.name %></option>
                      <% }) %>
                    <% } %>
                  </select>
                </div>
              </div>
            </div>
          </div>

          <div class="column is-3">
            <div class="field">
              <label class="label">Member</label>
              <div class="control">
                <div class="select is-fullwidth">
                  <select id="teamHistoryUserFilter" name="user_id">
                    <option value="">All members</option>
                    <% team.members.forEach((member) => { %>
                      <option value="<%= member.user_id %>" <%= String(member.user_id) === String(filters.userId || '') ? 'selected' : '' %>><%= member.full_name %> (<%= member.email %>)</option>
                    <% }) %>
                  </select>
                </div>
              </div>
            </div>
          </div>

          <div class="column is-2">
            <div class="field">
              <label class="label">Date</label>
              <div class="control">
                <input
                  id="teamHistoryDateFilter"
                  class="input"
                  type="date"
                  name="date"
                  value="<%= filters.date || '' %>"
                >
              </div>
            </div>
          </div>

          <div class="column is-1">
            <div class="field mt-5">
              <div class="buttons control">
                <button id="teamHistorySearchBtn" type="submit" class="button is-primary is-fullwidth">Search</button>
              </div>
            </div>
          </div>
          <div class="column is-1">
            <div class="field mt-5">
              <div class="buttons control">
                <button id="teamHistoryClearBtn" type="button" class="button is-light">Clear filters</button>
              </div>
            </div>
          </div>
        </div>

      </form>
    </div>

    <div class="box">
      <div class="content mb-4">
        <h3 id="teamHistoryTitle" class="title is-5 mb-1">Standups from <%= team.team_name %></h3>
      </div>

      <div id="teamHistoryEmptyState" class="notification is-warning is-light <%= standups && standups.length > 0 ? 'is-hidden' : '' %>">
        No records found for the selected filters.
      </div>

      <div id="teamHistoryTableContainer" class="table-container <%= !standups || standups.length === 0 ? 'is-hidden' : '' %>">
        <table class="table is-fullwidth is-striped is-hoverable is-narrow">
          <thead>
            <tr>
              <th>Date</th>
              <th>Email</th>
              <th>What did you do?</th>
              <th>What will you do tomorrow?</th>
              <th>Blockers</th>
            </tr>
          </thead>
          <tbody id="teamHistoryTableBody">
            <% standups.forEach((standup) => { %>
              <tr>
                <td><%= standup.date.toISOString().split('T')[0] %></td>
                <td><%= standup.email %></td>
                <td><%= standup.did_today %></td>
                <td><%= standup.do_tomorrow %></td>
                <td><%= standup.blockers || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('teamHistoryFiltersForm');
    const teamFilter = document.getElementById('teamHistoryTeamFilter');
    const userFilter = document.getElementById('teamHistoryUserFilter');
    const dateFilter = document.getElementById('teamHistoryDateFilter');
    const searchBtn = document.getElementById('teamHistorySearchBtn');
    const clearBtn = document.getElementById('teamHistoryClearBtn');
    const errorBox = document.getElementById('teamHistoryError');
    const errorText = document.getElementById('teamHistoryErrorText');
    const emptyState = document.getElementById('teamHistoryEmptyState');
    const tableContainer = document.getElementById('teamHistoryTableContainer');
    const tableBody = document.getElementById('teamHistoryTableBody');
    const title = document.getElementById('teamHistoryTitle');
    const endpoint = '/daily_standup/history/team/data';

    const escapeHtml = (value) => {
      return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
    };

    const formatDate = (value) => {
      if (!value) return '-';

      const text = String(value);
      if (text.length >= 10 && text[4] === '-' && text[7] === '-') {
        return text.slice(0, 10);
      }

      const parsed = new Date(value);
      if (Number.isNaN(parsed.getTime())) {
        return '-';
      }

      return parsed.toISOString().split('T')[0];
    };

    const setLoading = (isLoading) => {
      searchBtn.disabled = isLoading;
      clearBtn.disabled = isLoading;
      searchBtn.textContent = isLoading ? 'Loading...' : 'Search';
    };

    const showError = (message) => {
      errorText.textContent = message || 'Unknown error';
      errorBox.classList.remove('is-hidden');
    };

    const renderMemberOptions = (team) => {
      const members = (team && team.members) ? team.members : [];
      const currentValue = userFilter.value || '';

      const optionsHtml = [
        '<option value="">All members</option>',
        ...members.map((member) => {
          const value = String(member.user_id);
          const label = `${escapeHtml(member.full_name || '')} (${escapeHtml(member.email || '')})`;
          const selected = value === currentValue ? 'selected' : '';
          return `<option value="${escapeHtml(value)}" ${selected}>${label}</option>`;
        }),
      ].join('');

      userFilter.innerHTML = optionsHtml;
    };

    const hideError = () => {
      errorText.textContent = '';
      errorBox.classList.add('is-hidden');
    };

    const renderRows = (standups) => {
      if (!standups || standups.length === 0) {
        tableBody.innerHTML = '';
        tableContainer.classList.add('is-hidden');
        emptyState.classList.remove('is-hidden');
        return;
      }

      const rowsHtml = standups.map((standup) => {
        return `
          <tr>
            <td>${escapeHtml(formatDate(standup.date))}</td>
            <td>${escapeHtml(standup.email || '')}</td>
            <td>${escapeHtml(standup.did_today || '')}</td>
            <td>${escapeHtml(standup.do_tomorrow || '')}</td>
            <td>${escapeHtml(standup.blockers || '-')}</td>
          </tr>
        `;
      }).join('');

      tableBody.innerHTML = rowsHtml;
      tableContainer.classList.remove('is-hidden');
      emptyState.classList.add('is-hidden');
    };

    const updateBrowserUrl = (params) => {
      const query = params.toString();
      const target = '/daily_standup/history/team' + (query ? '?' + query : '');
      window.history.replaceState({}, '', target);
    };

    const fetchHistory = async () => {
      const params = new URLSearchParams();

      if (teamFilter && teamFilter.value) {
        params.set('team_id', teamFilter.value);
      }

      if (userFilter.value) {
        params.set('user_id', userFilter.value);
      }

      if (dateFilter.value) {
        params.set('date', dateFilter.value);
      }

      setLoading(true);
      hideError();

      try {
        const response = await fetch(endpoint + (params.toString() ? '?' + params.toString() : ''), {
          method: 'GET',
          headers: {
            'Accept': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
          },
        });

        const payload = await response.json();

        if (!response.ok || !payload.ok) {
          showError(payload.error || 'Error loading standup history.');
          renderRows([]);
          return;
        }

        if (payload.team && payload.team.team_name) {
          title.textContent = 'Standups from ' + payload.team.team_name;
        }

        if (payload.team) {
          renderMemberOptions(payload.team);
        }

        renderRows(payload.standups || []);
        updateBrowserUrl(params);
      } catch (error) {
        showError('Server connection error. Please try again later.');
      } finally {
        setLoading(false);
      }
    };

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      fetchHistory();
    });

    if (teamFilter) {
      teamFilter.addEventListener('change', () => {
        userFilter.value = '';
        dateFilter.value = '';
        fetchHistory();
      });
    }

    if (userFilter) {
      userFilter.addEventListener('change', () => {
        fetchHistory();
      });
    }

    clearBtn.addEventListener('click', () => {
      userFilter.value = '';
      dateFilter.value = '';
      fetchHistory();
    });
  });
</script>

<%- include('includes/_footer') %>