<section class="section">
    <div class="container">
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="notification is-success is-light" id="successNotification">
                <button class="delete"></button>
                <strong><%= success %></strong>
            </div>
            <script>
                // Auto-close notification after 4 seconds
                setTimeout(() => {
                    const notification = document.getElementById('successNotification');
                    if (notification) {
                        notification.remove();
                    }
                }, 3000);

                // Close notification on button click
                document.addEventListener('DOMContentLoaded', () => {
                    const closeButtons = document.querySelectorAll('.notification .delete');
                    closeButtons.forEach(button => {
                        button.addEventListener('click', () => {
                            button.parentElement.remove();
                        });
                    });
                });
            </script>
        <% } %>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="notification is-danger is-light" id="errorNotification">
                <button class="delete"></button>
                <strong><%= error %></strong>
            </div>
            <script>
                setTimeout(() => {
                    const notification = document.getElementById('errorNotification');
                    if (notification) {
                        notification.remove();
                    }
                }, 3000);
            </script>
        <% } %>

        <div class="level mb-4">
            <div class="level-left">
                <h1 class="title">Project Management</h1>
            </div>
            <div class="level-right">
                <a href="/projects/add" class="button is-warning"><strong>+ New Project</strong></a>
            </div>
        </div>

        <div class="box">
            <table class="table is-fullwidth is-striped is-hoverable">
                <thead>
                    <tr>
                        <th>Project Name</th>
                        <th>Status</th>
                        <th>Team</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th class="has-text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof projects !== 'undefined' && projects.length > 0) { %>
                        <% projects.forEach(project => { %>
                            <tr>
                                <td class="is-vcentered">
                                    <strong><%= project.name %></strong>
                                    <% if (project.description) { %>
                                        <br><small class="has-text-grey"><%= project.description.substring(0, 60) %><%= project.description.length > 60 ? '...' : '' %></small>
                                    <% } %>
                                </td>
                                <td class="is-vcentered">
                                    <% if (project.status === 'active') { %>
                                        <span class="tag is-success is-light">Active</span>
                                    <% } else if (project.status === 'inactive') { %>
                                        <span class="tag is-warning is-light">Inactive</span>
                                    <% } else { %>
                                        <span class="tag is-light"><%= project.status %></span>
                                    <% } %>
                                </td>
                                <td class="is-vcentered">
                                    <% if (project.team_name) { %>
                                        <span class="tag is-info is-light"><%= project.team_name %></span>
                                    <% } else { %>
                                        <span class="tag is-light">No team</span>
                                    <% } %>
                                </td>
                                <td class="is-vcentered">
                                    <%= project.start_date ? new Date(project.start_date).toLocaleDateString() : '—' %>
                                </td>
                                <td class="is-vcentered">
                                    <%= project.end_date ? new Date(project.end_date).toLocaleDateString() : '—' %>
                                </td>
                                <td class="has-text-right is-vcentered">
                                    <div class="buttons is-right">
                                        <a href="/projects/link/<%= project.project_id %>" class="button is-small is-info is-outlined">Link Team</a>
                                        <a href="/projects/edit/<%= project.project_id %>" class="button is-small is-light">Edit</a>

                                        <form action="/projects/delete/<%= project.project_id %>" method="POST"
                                            style="display:inline;">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit"
                                                class="button is-small is-danger is-outlined"
                                                onclick="return confirm('Are you sure you want to delete this project?');">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="has-text-centered has-text-grey py-5">
                                No projects registered yet.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</section>