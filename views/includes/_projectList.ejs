<section class="section">
    <div class="container">
        <%
            const statusCounter = {};
            if (typeof projects !== 'undefined' && projects.length > 0) {
                projects.forEach((project) => {
                    const statusKey = (project.status || 'unknown').toLowerCase();
                    statusCounter[statusKey] = (statusCounter[statusKey] || 0) + 1;
                });
            }

            const statusEntries = Object.entries(statusCounter);
            const totalProjects = statusEntries.reduce((sum, [, count]) => sum + count, 0);
            const statusColorMap = {
                completed: '#3e8ed0',
                active: '#48c78e',
                paused: '#ffdd57',
            };
            const fallbackColors = ['#f14668', '#b86bff', '#7a7a7a', '#00d1b2', '#ff3860'];
            let fallbackColorIndex = 0;

            let cumulative = 0;
            const chartSegments = statusEntries.map(([status, count], index) => {
                const startDeg = totalProjects ? (cumulative / totalProjects) * 360 : 0;
                cumulative += count;
                const endDeg = totalProjects ? (cumulative / totalProjects) * 360 : 0;

                return {
                    status,
                    count,
                    color: statusColorMap[status] || fallbackColors[fallbackColorIndex++ % fallbackColors.length],
                    startDeg,
                    endDeg,
                    percentage: totalProjects ? Math.round((count / totalProjects) * 100) : 0,
                };
            });

            const pieGradient = chartSegments.length > 0
                ? `conic-gradient(${chartSegments.map((segment) => `${segment.color} ${segment.startDeg}deg ${segment.endDeg}deg`).join(', ')})`
                : 'conic-gradient(#dbdbdb 0deg 360deg)';
        %>

        <% if (typeof success !== 'undefined' && success) { %>
            <div class="notification is-success is-light" id="successNotification">
                <button class="delete"></button>
                <strong><%= success %></strong>
            </div>
            <script>
                // Auto-close notification after 4 seconds
                setTimeout(() => {
                    const notification = document.getElementById('successNotification');
                    if (notification) {
                        notification.remove();
                    }
                }, 3000);

                // Close notification on button click
                document.addEventListener('DOMContentLoaded', () => {
                    const closeButtons = document.querySelectorAll('.notification .delete');
                    closeButtons.forEach(button => {
                        button.addEventListener('click', () => {
                            button.parentElement.remove();
                        });
                    });
                });
            </script>
        <% } %>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="notification is-danger is-light" id="errorNotification">
                <button class="delete"></button>
                <strong><%= error %></strong>
            </div>
            <script>
                setTimeout(() => {
                    const notification = document.getElementById('errorNotification');
                    if (notification) {
                        notification.remove();
                    }
                }, 3000);
            </script>
        <% } %>

        <div class="level mb-4">
            <div class="level-left">
                <h1 class="title">Project Management</h1>
            </div>
            <div class="level-right">
                <a href="/projects/add" class="button is-primary"><strong>+ New Project</strong></a>
            </div>
        </div>

        <div class="box">
            <table class="table is-fullwidth is-striped is-hoverable">
                <thead>
                    <tr>
                        <th>Project Name</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Team</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th class="has-text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof projects !== 'undefined' && projects.length > 0) { %>
                        <% projects.forEach(project => { %>
                            <tr>
                                <td class="is-vcentered">
									<a href="/projects/details/<%= project.project_id %>" class=" is-small is-link">
										<strong><%= project.name %></strong>
									</a>
								</td>
                                <td class="is-vcentered">
                                    <% if (project.description) { %>
                                        <span class="has-text-grey"><%= project.description.substring(0, 60) %><%= project.description.length > 60 ? '...' : '' %></span>
                                    <% } else { %>
                                        <span class="has-text-grey-light">—</span>
                                    <% } %>
                                </td>
                                <td class="is-vcentered">
                                    <% if (project.status === 'active') { %>
                                        <span class="tag is-success is-light">Active</span>
                                    <% } else if (project.status === 'inactive') { %>
                                        <span class="tag is-warning is-light">Inactive</span>
                                    <% } else { %>
                                        <span class="tag is-light"><%= project.status %></span>
                                    <% } %>
                                </td>
                                <td class="is-vcentered">
                                    <% if (project.team_name) { %>
                                        <span class="tag is-info is-light"><%= project.team_name %></span>
                                    <% } else { %>
                                        <span class="tag is-light">No team</span>
                                    <% } %>
                                </td>
                                <td class="is-vcentered">
                                    <%= project.start_date ? new Date(project.start_date).toLocaleDateString() : '—' %>
                                </td>
                                <td class="is-vcentered">
                                    <%= project.end_date ? new Date(project.end_date).toLocaleDateString() : '—' %>
                                </td>
                                <td class="has-text-right is-vcentered">
                                    <div class="buttons is-right">
                                        <a href="/projects/report/<%= project.project_id %>" class="button is-small is-dark">AI Report</a>
                                        <a href="/projects/edit/<%= project.project_id %>" class="button is-small is-light">Edit</a>

                                        <form action="/projects/delete/<%= project.project_id %>" method="POST"
                                            style="display:inline;">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit"
                                                class="button is-small is-light"
                                                onclick="return confirm('Are you sure you want to delete this project?');">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="has-text-centered has-text-grey py-5">
                                No projects registered yet.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <div class="box">
            <div class="is-flex is-justify-content-space-between is-align-items-center mb-4">
                <h2 class="subtitle mb-0">Project Status Summary</h2>
                <button
                    id="toggleStatusSummary"
                    type="button"
                    class="button is-small is-light"
                    aria-controls="statusSummaryContent"
                    aria-expanded="false">
                    Show Summary
                </button>
            </div>

            <div id="statusSummaryContent" style="display:none;">
                <% if (chartSegments.length > 0) { %>
                    <div style="display:flex; flex-wrap:wrap; gap:1.5rem; align-items:center;">
                        <div
                            style="width:180px; height:180px; border-radius:50%; background:<%= pieGradient %>; border:1px solid #e5e5e5;"
                            aria-label="Pie chart with project statuses"
                            role="img">
                        </div>

                        <div>
                            <% chartSegments.forEach((segment) => { %>
                                <div style="display:flex; align-items:center; margin-bottom:0.5rem;">
                                    <span style="display:inline-block; width:12px; height:12px; border-radius:50%; margin-right:0.5rem; background:<%= segment.color %>;"></span>
                                    <span>
                                        <strong><%= segment.status.charAt(0).toUpperCase() + segment.status.slice(1) %></strong>:
                                        <%= segment.count %> (<%= segment.percentage %>%)
                                    </span>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                <% } else { %>
                    <p class="has-text-grey">No projects available to display status chart.</p>
                <% } %>
            </div>

            <script>
                document.addEventListener('DOMContentLoaded', () => {
                    const toggleButton = document.getElementById('toggleStatusSummary');
                    const summaryContent = document.getElementById('statusSummaryContent');

                    if (!toggleButton || !summaryContent) {
                        return;
                    }

                    toggleButton.addEventListener('click', () => {
                        const isHidden = summaryContent.style.display === 'none';
                        summaryContent.style.display = isHidden ? 'block' : 'none';
                        toggleButton.textContent = isHidden ? 'Hide Summary' : 'Show Summary';
                        toggleButton.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
                    });
                });
            </script>
        </div>
    </div>
</section>