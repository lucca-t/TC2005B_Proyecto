<section class="section">
    <div class="container">
        <div class="level mb-4">
            <div class="level-left">
                <h1 class="title">Edit Team</h1>
            </div>
            <div class="level-right">
                <a href="/teams/list" class="button is-light"><strong>← Back</strong></a>
            </div>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="notification is-danger is-light mb-4" id="errorNotification">
                <button class="delete"></button>
                <strong><%= error %></strong>
            </div>
        <% } %>

        <div class="columns">
            <!-- LEFT: TEAM INFO -->
            <div class="column is-5">
                <div class="box">
                    <h2 class="subtitle has-text-centered mb-5">Team Information</h2>

                    <div class="field">
                        <label class="label">Team Name</label>
                        <div class="control">
                            <input class="input" type="text" value="<%= teamName || 'N/A' %>" disabled>
                        </div>
                    </div>

                    <hr>

                    <div class="field">
                        <label class="label has-text-weight-bold">Current Members: <span class="tag is-primary"><%= members.length %></span></label>
                    </div>

                    <div class="box" style="background-color: #fafafa; border: 1px solid #dbdbdb; max-height: 250px; overflow-y: auto;">
                        <% if (members && members.length > 0) { %>
                            <% members.forEach(member => { %>
                                <div style="padding-bottom: 8px; margin-bottom: 8px; border-bottom: 1px solid #eaeaea;">
                                    <p><strong><%= member.full_name %></strong></p>
                                    <p class="has-text-grey is-size-7"><%= member.email %></p>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="has-text-grey has-text-centered">No members in this team</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- RIGHT: MEMBER SELECTOR -->
            <div class="column is-7">
                <div class="box">
                    <h2 class="subtitle mb-4">Quick Assign Members</h2>

                    <form action="/teams/edit/<%= teamId %>" method="POST" id="teamEditForm">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        
                        <!-- SEARCH -->
                        <div class="field mb-4">
                            <div class="control">
                                <input id="searchInput" class="input" type="text" placeholder="Search user by name or email...">
                            </div>
                        </div>

                        <!-- TABLE with CHECKBOXES -->
                        <div style="max-height: 400px; overflow-y: auto; border: 1px solid #dbdbdb; border-radius: 4px;">
                            <table class="table is-fullwidth is-striped" style="margin-bottom: 0;">
                                <thead style="position: sticky; top: 0; background-color: #f5f5f5;">
                                    <tr>
                                        <th style="width: 50px;">Select</th>
                                        <th>User</th>
                                    </tr>
                                </thead>
                                <tbody id="userTable">
                                    <% if (typeof allUsers !== 'undefined' && allUsers.length > 0) { %>
                                        <% 
                                            // Debug: Log the data structure
                                            console.log('[DEBUG _teamEdit.ejs] ====== RENDER LOOP START ======');
                                            console.log('[DEBUG _teamEdit.ejs] members:', members);
                                            console.log('[DEBUG _teamEdit.ejs] members is array?', Array.isArray(members));
                                            console.log('[DEBUG _teamEdit.ejs] members length:', members ? members.length : 'undefined');
                                            if (members && Array.isArray(members)) {
                                                console.log('[DEBUG _teamEdit.ejs] member IDs:', members.map(m => ({ id: m.user_id, type: typeof m.user_id, full_name: m.full_name })));
                                            }
                                            console.log('[DEBUG _teamEdit.ejs] allUsers count:', allUsers.length);
                                        %>
                                        <% allUsers.forEach(user => {
                                            const userId = parseInt(user.user_id);
                                            const userIdOrig = user.user_id;
                                            
                                            // Safely check if user is a member
                                            let isMember = false;
                                            if (Array.isArray(members) && members.length > 0) {
                                                isMember = members.some(m => {
                                                    const memberId = parseInt(m.user_id);
                                                    const isMatch = memberId === userId;
                                                    if (user.user_id === allUsers[0].user_id) { // Log only for first user to avoid spam
                                                        console.log(`[DEBUG] Comparing user ${userIdOrig}(${userId}) vs member ${m.user_id}(${memberId}): ${isMatch}`);
                                                    }
                                                    return isMatch;
                                                });
                                            }
                                            
                                            console.log(`[DEBUG _teamEdit.ejs] User ${user.full_name} (${userIdOrig}): isMember=${isMember}`);
                                        %>
                                            <tr class="user-row" data-search="<%= (user.full_name + ' ' + user.email).toLowerCase() %>">
                                                <td style="text-align: center; vertical-align: middle;">
                                                    <input 
                                                        type="checkbox" 
                                                        class="user-checkbox" 
                                                        value="<%= user.user_id %>"
                                                        data-user-id="<%= userId %>"
                                                        <%= isMember ? 'checked' : '' %>
                                                    >
                                                </td>
                                                <td>
                                                    <div>
                                                        <strong><%= user.full_name %></strong>
                                                    </div>
                                                    <p class="has-text-grey is-size-7"><%= user.email %></p>
                                                </td>
                                            </tr>
                                        <% }) %>
                                        <% console.log('[DEBUG _teamEdit.ejs] ====== RENDER LOOP END ======'); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="2" class="has-text-centered has-text-grey py-5">
                                                No users available.
                                            </td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                        <!-- HIDDEN INPUT FOR USER IDS -->
                        <input type="hidden" id="userIdsInput" name="userIds" value="">

                        <div class="field mt-5">
                            <div class="control">
                                <button type="submit" class="button is-primary is-fullwidth is-medium">
                                    <strong>Save Team Changes</strong>
                                </button>
                            </div>
                        </div>

                    </form>

                    <p class="has-text-grey mt-3 is-size-7">
                        ✓ Check members to include them in the team
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- JS -->
<script>
    // ERROR NOTIFICATION AUTO-CLOSE
    document.addEventListener('DOMContentLoaded', () => {
        const closeButtons = document.querySelectorAll('.notification .delete');
        closeButtons.forEach(button => {
            button.addEventListener('click', () => {
                button.parentElement.remove();
            });
        });
        
        // Debug: Check which checkboxes are actually checked
        console.log('[DEBUG client-side] Page loaded');
        const checkedBoxes = document.querySelectorAll('.user-checkbox:checked');
        console.log('[DEBUG client-side] Checked checkboxes count:', checkedBoxes.length);
        checkedBoxes.forEach(cb => {
            console.log('[DEBUG client-side] Checked user:', cb.value, 'data-user-id:', cb.getAttribute('data-user-id'));
        });
    });

    // SEARCH FILTER
    const searchInput = document.getElementById('searchInput');
    const rows = document.querySelectorAll('.user-row');

    searchInput.addEventListener('keyup', function() {
        const searchTerm = this.value.toLowerCase();
        rows.forEach(row => {
            const searchData = row.getAttribute('data-search');
            if (searchData.includes(searchTerm)) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    });

    // HANDLE FORM SUBMISSION - COLLECT CHECKED USER IDS
    document.getElementById('teamEditForm').addEventListener('submit', function(e) {
        const checkboxes = document.querySelectorAll('.user-checkbox:checked');
        const userIds = Array.from(checkboxes).map(cb => cb.value).join(',');
        document.getElementById('userIdsInput').value = userIds;
        console.log('Selected User IDs for submission:', userIds);
        console.log('Number of checked checkboxes:', checkboxes.length);
        
        // If no checkboxes are checked, send empty string to remove all members
        if (checkboxes.length === 0) {
            console.log('No users selected - all current members will be removed');
        }
    });
</script>