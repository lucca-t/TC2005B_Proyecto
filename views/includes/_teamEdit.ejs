<section class="section">
    <div class="container" style="max-width: 700px;">

        <div class="box">
            <form action="/teams/update/1" method="POST">

                <div class="level mb-2">
                    <div class="level-left">
                        <h2 class="title is-4">Team Details</h2>
                    </div>
                </div>

                <div class="field">
                    <label class="label">Team Name</label>
                    <div class="control">
                        <input class="input is-medium" type="text" name="teamName" value="Ositos" required>
                    </div>
                </div>

                <hr>

                <h3 class="title is-5 mb-3">Current Members</h3>

                <div class="box" style="background-color: #fafafa; border: 1px solid #dbdbdb;">

                    <div class="level is-mobile"
                        style="border-bottom: 1px solid #eaeaea; padding-bottom: 10px; margin-bottom: 10px;">
                        <div class="level-left">
                            <div class="level-item">
                                <p>
                                    <strong>Joel Garcia</strong>
                                    <span class="tag is-warning is-light ml-2">Lead</span>
                                </p>
                            </div>
                        </div>

                        <div class="level-right">
                            <div class="level-item">
                                <div class="dropdown is-right is-hoverable">
                                    <div class="dropdown-trigger">
                                        <button type="button" class="button is-small is-ghost" aria-haspopup="true">
                                            <span style="font-size: 1.2rem; font-weight: bold;">&#8942;</span>
                                        </button>
                                    </div>
                                    <div class="dropdown-menu" role="menu">
                                        <div class="dropdown-content">
                                            <a href="#dummy-make-lead" class="dropdown-item">
                                                Make lead member
                                            </a>
                                            <hr class="dropdown-divider">
                                            <a href="#dummy-remove" class="dropdown-item has-text-danger">
                                                Remove member
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="level is-mobile"
                        style="border-bottom: 1px solid #eaeaea; padding-bottom: 10px; margin-bottom: 10px;">
                        <div class="level-left">
                            <div class="level-item">
                                <p>
                                    <strong>Alice Smith</strong>
                                </p>
                            </div>
                        </div>

                        <div class="level-right">
                            <div class="level-item">
                                <div class="dropdown is-right is-hoverable">
                                    <div class="dropdown-trigger">
                                        <button type="button" class="button is-small is-ghost" aria-haspopup="true">
                                            <span style="font-size: 1.2rem; font-weight: bold;">&#8942;</span>
                                        </button>
                                    </div>
                                    <div class="dropdown-menu" role="menu">
                                        <div class="dropdown-content">
                                            <a href="#dummy-make-lead" class="dropdown-item">
                                                Make lead member
                                            </a>
                                            <hr class="dropdown-divider">
                                            <a href="#dummy-remove" class="dropdown-item has-text-danger">
                                                Remove member
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="button" class="button is-small is-info is-light">
                            + Add more members
                        </button>
                    </div>

                </div>

                <div class="field mt-5">
                    <div class="control">
                        <button type="submit" class="button is-warning is-fullwidth is-medium">
                            <strong>Save changes</strong>
                        </button>
                    </div>
                </div>

            </form>
        </div>

    </div>
</section>