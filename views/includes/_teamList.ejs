<section class="section">
    <style>
        .quarter-dot {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin: 0 2px;
        }

        .quarter-dot.is-filled {
            background-color: #3273dc;
        }

        .quarter-dot.is-empty {
            background-color: #dbdbdb;
        }
    </style>

    <div class="container">
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="notification is-success is-light" id="successNotification">
                <button class="delete"></button>
                <strong><%= success %></strong>
            </div>
            <script>
                // Auto-close notification after 4 seconds
                setTimeout(() => {
                    const notification = document.getElementById('successNotification');
                    if (notification) {
                        notification.remove();
                    }
                }, 3000);

                // Close notification on button click
                document.addEventListener('DOMContentLoaded', () => {
                    const closeButtons = document.querySelectorAll('.notification .delete');
                    closeButtons.forEach(button => {
                        button.addEventListener('click', () => {
                            button.parentElement.remove();
                        });
                    });
                });
            </script>
        <% } %>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="notification is-danger is-light" id="errorNotification">
                <button class="delete"></button>
                <strong><%= error %></strong>
            </div>
            <script>
                setTimeout(() => {
                    const notification = document.getElementById('errorNotification');
                    if (notification) {
                        notification.remove();
                    }
                }, 3000);

                document.addEventListener('DOMContentLoaded', () => {
                    const closeButtons = document.querySelectorAll('.notification .delete');
                    closeButtons.forEach(button => {
                        button.addEventListener('click', () => {
                            button.parentElement.remove();
                        });
                    });
                });
            </script>
        <% } %>
        <div class="level mb-4">
            <div class="level-left">
                <h1 class="title">Team Management</h1>
            </div>
            <div class="level-right">
                <% if (typeof role !== 'undefined' && (role === 'Administrador' 
                || role === 'Lead Member')) { %>
                <a href="/teams/add" class="button is-primary"><strong>+ New Team</strong></a>
                <% } %>
            </div>
        </div>

        <div id="teamSearchMeta"
            data-role="<%= typeof role !== 'undefined' ? role : '' %>"
            data-csrf="<%= csrfToken %>"
            style="display:none;"></div>

        <div class="field has-addons mb-4">
            <div class="control is-expanded has-icons-left">
                <input id="teamSearchInput" class="input" type="text"
            placeholder="Search teams by name..."
            autocomplete="off" maxlength="100">
                <span class="icon is-left"><i class="fas fa-search"></i></span>
            </div>
            <div class="control">
                <button id="teamSearchClear" class="button is-light" type="button" title="Clear search">
                    <span class="icon"><i class="fas fa-times"></i></span>
                </button>
            </div>
        </div>

        <div class="box">
            <table class="table is-fullwidth is-striped is-hoverable">
                <thead>
                    <tr>
                        <th>Team Name</th>
                        <th>Members</th>
                        <th class="has-text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="teamsTableBody">
                    <% if (typeof teams !=='undefined' && teams.length> 0) { %>
                        <% teams.forEach(team=> { %>
                            <tr>
                                <td class="is-vcentered">
                                    <strong>
                                        <a href="/teams/details/<%= team.id %>" class="is-small is-link"><%= team.name %></a>
                                    </strong>
                                    <% if (team.isCurrentUserTeam) { %>
                                        <span class="tag is-success is-light ml-2">Your Team</span>
                                    <% } %>
                                </td>
                                <td class="is-vcentered">
                                    <span class="tag is-info is-light"><%= team.memberCount %> members</span>
                                </td>
                                <td class="has-text-right is-vcentered">
                                    <div class="buttons is-right">
                                        <% const qp = team.quarterProgress || 0; %>
                                        <span title="<%= qp %>/3 months reported this quarter"
                                            style="display:inline-flex;align-items:center;margin-right:4px;">
                                            <% for (let i = 0; i < 3; i++) { %>
                                                <span class="quarter-dot <%= i < qp ? 'is-filled' : 'is-empty' %>"></span>
                                            <% } %>
                                            <span style="font-size:0.72rem;color:#555;margin-left:4px;"><%= qp %>/3</span>
                                        </span>
                                        <a href="/teams/details/<%= team.id %>" class="button is-small is-info is-light">Standup History</a>
                                        <a href="/teams/report/<%= team.id %>" class="button is-small is-dark">AI Report</a>

                                        <% if (typeof role !== 'undefined' && (role === 'Administrador' || role === 'Lead Member')) { %>
                                        <a href="/teams/edit/<%= team.id %>" class="button is-small is-light">Edit</a>

                                        <form action="/teams/delete/<%= team.id %>" method="POST"
                                            style="display:inline;">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit"
                                                class="button is-small is-light"
                                                onclick="return confirm('Are you sure you want to delete this team?');">Delete</button>
                                        </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="3" class="has-text-centered has-text-grey py-5">
                                            No teams registered yet.
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        (function () {
            const input = document.getElementById('teamSearchInput');
            const clearBtn = document.getElementById('teamSearchClear');
            const tbody = document.getElementById('teamsTableBody');
            const meta = document.getElementById('teamSearchMeta');

            if (!input || !tbody || !meta) return;

            const userRole = meta.dataset.role;
            const csrfToken = meta.dataset.csrf;
            const isAdminOrLead = userRole === 'Administrador' || userRole === 'Lead Member';
            const originalRows = tbody.innerHTML;

            let debounceTimer = null;
            let currentController = null;

            function escapeHtml(str) {
                const div = document.createElement('div');
                div.appendChild(document.createTextNode(String(str)));
                return div.innerHTML;
            }

            function buildRow(team) {
                const filled = team.quarterProgress || 0;
                const bg = function(i) {
                    return i < filled ? '#3273dc' : '#dbdbdb';
                };
                const dot = function(i) {
                    return '<span style="display:inline-block;' +
                        'width:10px;height:10px;' +
                        'border-radius:50%;margin:0 2px;' +
                        'background:' + bg(i) + ';"></span>';
                };
                const dots = [0, 1, 2].map(dot).join('');
                const qTitle =
                    filled + '/3 months reported this quarter';
                const qLabel =
                    '<span style="font-size:0.72rem;color:#555;' +
                    'margin-left:4px;">' + filled + '/3</span>';
                const progressBadge =
                    '<span title="' + qTitle + '"' +
                    ' style="display:inline-flex;' +
                    'align-items:center;margin-right:4px;">' +
                    dots + qLabel + '</span>';

                const membershipBadge = team.isCurrentUserTeam
                    ? '<span class="tag is-success is-light ml-2">Your Team</span>'
                    : '';

                const adminActions = isAdminOrLead ? `
                    <a href="/teams/edit/${team.id}" class="button is-small is-light">Edit</a>
                    <form action="/teams/delete/${team.id}" method="POST" style="display:inline;">
                        <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}">
                        <button type="submit" class="button is-small is-light"
                            onclick="return confirm('Are you sure you want to delete this team?');">Delete</button>
                    </form>` : '';

                return `<tr>
                    <td class="is-vcentered"><strong>
                        <a href="/teams/details/${team.id}" class="is-small is-link">${escapeHtml(team.name)}</a>
                    </strong>${membershipBadge}</td>
                    <td class="is-vcentered">
                        <span class="tag is-info is-light">${team.memberCount} members</span>
                    </td>
                    <td class="has-text-right is-vcentered">
                        <div class="buttons is-right">
                            ${progressBadge}
                            <a href="/teams/report/${team.id}" class="button is-small is-dark">AI Report</a>
                            ${adminActions}
                        </div>
                    </td>
                </tr>`;
            }

            function renderResults(teams) {
                if (teams.length === 0) {
                    tbody.innerHTML = `<tr>
                        <td colspan="3" class="has-text-centered has-text-grey py-5">
                            No teams match your search.
                        </td>
                    </tr>`;
                    return;
                }
                tbody.innerHTML = teams.map(buildRow).join('');
            }

            function resetToOriginal() {
                if (currentController) currentController.abort();
                clearTimeout(debounceTimer);
                tbody.innerHTML = originalRows;
            }

            function doSearch(query) {
                if (currentController) currentController.abort();
                currentController = new AbortController();

                const controlDiv = input.closest('.control');
                if (controlDiv) controlDiv.classList.add('is-loading');

                fetch('/teams/search?q=' + encodeURIComponent(query), {
                    signal: currentController.signal,
                    headers: { 'Accept': 'application/json' }
                })
                .then(function (res) {
                    if (!res.ok) throw new Error('Network error');
                    return res.json();
                })
                .then(function (data) {
                    renderResults(data.teams || []);
                })
                .catch(function (err) {
                    if (err.name === 'AbortError') return;
                    tbody.innerHTML = originalRows;
                })
                .finally(function () {
                    if (controlDiv) controlDiv.classList.remove('is-loading');
                });
            }

            input.addEventListener('input', function () {
                clearTimeout(debounceTimer);
                const q = input.value.trim();
                if (!q) { resetToOriginal(); return; }
                debounceTimer = setTimeout(function () { doSearch(q); }, 300);
            });

            input.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    input.value = '';
                    resetToOriginal();
                }
            });

            clearBtn.addEventListener('click', function () {
                input.value = '';
                resetToOriginal();
                input.focus();
            });
        }());
    </script>
</section>