<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Daily Standup+</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
</head>

<body>
  <nav class="navbar is-transparent" role="navigation" aria-label="main navigation">
    <div class="navbar-brand">
      <a class="navbar-item" href="/prototype">
        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/b/b0/Change.org_logo.svg/500px-Change.org_logo.svg.png" alt="Logo Daily Standup+" style="max-height: 70px;">
      </a>

      <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="navbarBasicExample">
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </a>
    </div>

    <div id="navbarBasicExample" class="navbar-menu">
      <div class="navbar-start">
        <a class="navbar-item" href="/personajes">
          Personajes
        </a>
      </div>

      <div class="navbar-end">
        <div class="navbar-item">
          <div class="buttons">
            <a class="button is-primary" href="/users/signup">
              <strong>Sign up</strong>
            </a>
            <% if (username=='' ) { %>
              <a class="button is-light" href="/users/login">
                Log in
              </a>
              <% } else { %>
                <a class="button is-light" href="/users/logout">
                  Log out
                </a>
                <% } %>
          </div>
        </div>
      </div>
    </div>
  </nav>


  <section class="section">
    <div class="container" id="upperTitle">
      <h1 class="title">
        <a href="/prototype">Daily Standup+</a>
      </h1>
    </div>
  </section>
  <div class="content px-6 mx-6">