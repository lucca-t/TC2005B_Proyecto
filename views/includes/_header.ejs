<%
  const userIsLoggedIn = typeof isLoggedIn !== 'undefined' ? isLoggedIn : false;
  const rawRole = typeof role !== 'undefined' && role !== null ? String(role).trim().toLowerCase() : '';
  const roleAliases = {
    administrador: 'Administrador',
    admin: 'Administrador',
    'lead member': 'Lead Member',
    lead: 'Lead Member',
    member: 'Member',
  };
  const userRole = roleAliases[rawRole] || null;
  const hasBaseAccess = userRole === 'Administrador' || userRole === 'Lead Member' || userRole === 'Member';
  const canManageUsersAndTeams = userRole === 'Administrador';
  const canManageProjects = userRole === 'Administrador' || userRole === 'Lead Member';
%>

<!DOCTYPE html>
<html data-theme="light" lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Daily Standup+</title>
  <link rel="stylesheet" href="/css/bulma.min.css">
  <link rel="stylesheet" href="/css/cssExtraStyles.css"> 
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
  <nav class="navbar is-light" role="navigation" aria-label="main navigation">
    <div class="navbar-brand">
      <a class="navbar-item" style="margin-left: 50px; height: 100px; width: 200px;" href="/users/list">
        <img
          src="https://upload.wikimedia.org/wikipedia/commons/thumb/b/b0/Change.org_logo.svg/500px-Change.org_logo.svg.png"
          alt="Logo Daily Standup+" style="max-height: 70px;">
      </a>

      <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="navbarMain">
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </a>
    </div>

    <div id="navbarMain" class="navbar-menu">
      <div class="navbar-start">
        <% if (userIsLoggedIn) { %>

        <% if (hasBaseAccess) { %>
        <div class="navbar-item has-dropdown is-hoverable">
          <a href="/users/list" class="navbar-link">Users</a>
          <div class="navbar-dropdown">
            <% if (canManageUsersAndTeams) { %>
            <a href="/users/add" class="navbar-item">Register New User</a>
            <% } else { %>
            <a href="#" class="navbar-item" onclick="showPermissionModal(); return false;">Register New User</a>
            <% } %>
            <a href="/users/report/history" class="navbar-item">Users list</a>
          </div>
        </div>
        <% } %>

        <% if (hasBaseAccess) { %>
        <div class="navbar-item has-dropdown is-hoverable">
          <a href="/teams/list" class="navbar-link">Teams</a>
          <div class="navbar-dropdown">
            <% if (canManageUsersAndTeams) { %>
            <a href="/teams/add" class="navbar-item">Register New Team</a>
            <% } else { %>
            <a href="#" class="navbar-item" onclick="showPermissionModal(); return false;">Register New Team</a>
            <% } %>
            <a href="/teams/list" class="navbar-item">Teams list</a>
          </div>
        </div>
        <% } %>
  
        <% if (hasBaseAccess) { %>
        <div class="navbar-item has-dropdown is-hoverable">   
          <a href="/projects/list" class="navbar-link">Projects</a>
          <div class="navbar-dropdown">
            <% if (canManageProjects) { %>
            <a href="/projects/add" class="navbar-item">Register New Project</a>
            <% } else { %>
            <a href="#" class="navbar-item" onclick="showPermissionModal(); return false;">Register New Project</a>
            <% } %>
            <a href="/projects/list" class="navbar-item">Project Management</a>
            <!-- <a href="/projects/report" class="navbar-item">Projects reports</a> -->
          </div>
        </div>
        <% } %>

        <% if (hasBaseAccess) { %>
        <div class="navbar-item has-dropdown is-hoverable">
          <a href="/daily_standup/history" class="navbar-link">Standup</a>
          <div class="navbar-dropdown">
            <a href="/daily_standup" class="navbar-item">Register Daily Standup</a>
            <a href="/daily_standup/history" class="navbar-item">Activity History</a>
            <% if (canManageProjects) { %>
            <a href="/daily_standup/history/team" class="navbar-item">Team Activity History</a>
            <% } %>
          </div>
        </div>
        <% } %>

        <% } %>
      </div>

      <div class="navbar-end">
        <div class="navbar-item">
          <div class="buttons">
            <% if (userIsLoggedIn) { %>
              <a class="button is-light" href="/logout">Log out</a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- Global permission denied modal -->
  <div id="permissionModal" class="modal">
    <div class="modal-background" onclick="closePermissionModal()"></div>
    <div class="modal-card">
      <header class="modal-card-head">
        <p class="modal-card-title">
          <span class="icon has-text-warning"><i class="fas fa-exclamation-triangle"></i></span>
          Access Denied
        </p>
        <button class="delete" aria-label="close" onclick="closePermissionModal()"></button>
      </header>
      <section class="modal-card-body">
        <p>Your Role doesn't have the permission to perform this function.</p>
      </section>
      <footer class="modal-card-foot">
        <button class="button is-warning" onclick="closePermissionModal()">OK</button>
      </footer>
    </div>
  </div>

  <!-- This is supposed to be a hamburguer menu on mobile -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const burger = document.querySelector('.navbar-burger');
      const menu = document.getElementById(burger.dataset.target);
      burger.addEventListener('click', () => {
        burger.classList.toggle('is-active');
        menu.classList.toggle('is-active');
      });

      // Auto-show modal if redirected with permissionDenied flag
      const params = new URLSearchParams(window.location.search);
      if (params.get('permissionDenied') === '1') {
        showPermissionModal();
        // Clean the URL
        const url = new URL(window.location);
        url.searchParams.delete('permissionDenied');
        window.history.replaceState({}, '', url);
      }
    });

    function showPermissionModal() {
      document.getElementById('permissionModal').classList.add('is-active');
    }

    function closePermissionModal() {
      document.getElementById('permissionModal').classList.remove('is-active');
    }
  </script>