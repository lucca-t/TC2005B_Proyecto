<section class="section">
    <div class="container">
        <div class="level mb-4">
            <div class="level-left">
                <h1 class="title">Team Details</h1>
            </div>
            <div class="level-right">
                <a href="/teams/list" class="button is-light"><strong>← Back to Teams</strong></a>
                    <a href="/teams/edit/<%= teamId %>" class="button is-primary"><strong>Edit Team</strong></a>
            </div>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="notification is-danger is-light mb-4" id="errorNotification">
                <button class="delete"></button>
                <strong><%= error %></strong>
            </div>
        <% } %>

        <div class="box">
            <h2 class="subtitle has-text-centered mb-5">Team Information</h2>

            <div class="field">
                <label class="label">Team Name</label>
                <div class="control">
                    <input class="input" type="text" value="<%= teamName || 'N/A' %>" disabled>
                </div>
            </div>

            <hr>

            <div class="field">
                <label class="label has-text-weight-bold">Current Members: <span class="tag is-primary"><%= members.length %></span></label>
            </div>

            <div class="box" style="background-color: #fafafa; border: 1px solid #dbdbdb; max-height: 400px; overflow-y: auto;">
                <% if (members && members.length > 0) { %>
                    <% members.forEach(member => { %>
                        <div class="media mb-3" style="padding-bottom: 10px;">
                            <div class="media-content">
                                <p class="title is-6"><%= member.slack_handle %></p>
                                <p class="subtitle is-7 has-text-grey"><%= member.email %></p>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="has-text-grey has-text-centered py-4">No members in this team</p>
                <% } %>
            </div>
        </div>

        <div class="box">
            <h2 class="subtitle has-text-centered mb-5">Last 3 Generated Reports</h2>

            <% if (reports && reports.length > 0) { %>
                <% reports.forEach(report => { %>
                    <div class="box mb-4" style="background-color: #f8f9fa; border: 1px solid #dbdbdb;">
                        <div class="level">
                            <div class="level-left">
                                <div>
                                    <p class="title is-6">Report #<%= report.report_id %></p>
                                    <p class="subtitle is-7 has-text-grey">
                                        Generated on <strong><%= report.date_generated ? report.date_generated : 'Unknown' %></strong>
                                    </p>
                                </div>
                            </div>
                            <div class="level-right">
                                <span class="tag is-info">Recent</span>
                            </div>
                        </div>
                        <div class="content">
                            <p><strong>Period:</strong>
                                <%= report.date_beginning ? report.date_beginning : 'N/A' %>
                                - <%= report.date_end ? report.date_end : 'N/A' %>
                            </p>
                            <p><strong>Summary:</strong></p>
                            <p class="has-text-grey">
                                <%= report.ai_content ? (report.ai_content.length > 220 ? report.ai_content.substring(0, 220) + '...' : report.ai_content) : 'No summary available.' %>
                            </p>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="has-text-grey has-text-centered py-4">No recent reports for this team.</p>
            <% } %>
        </div>
    </div>
</section>

<!-- JS -->
<script>
    // ERROR NOTIFICATION AUTO-CLOSE
    document.addEventListener('DOMContentLoaded', () => {
        const closeButtons = document.querySelectorAll('.notification .delete');
        closeButtons.forEach(button => {
            button.addEventListener('click', () => {
                button.parentElement.remove();
            });
        });
    });
</script>