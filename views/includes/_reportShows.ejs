<section class="section">
    <div class="container">
        <div class="level">
            <div class="level-left">
                <h1 class="title">
                    <% if (typeof user !== 'undefined' && user) { %>
                        Report for <%= user.full_name || user.email %>
                    <% } else { %>
                        Report from user/team/project
                    <% } %>
                </h1>
            </div>
            <div class="level-right">
                <% if (typeof user !== 'undefined' && user) { %>
                    <a href="/users/list" class="button is-light">Back to Users</a>
                <% } %>
            </div>
        </div>

        <div class="box">
            <div class="content">
                <% if (typeof report !== 'undefined' && report) { %>
                    <%- report.replace(/\n/g, '<br>') %>
                <% } else { %>
                    Here goes the content of the report
                <% } %>
            </div>
        </div>

        <div class="content has-text-right mt-2">
            <p class="is-size-5 has-text-grey">
                Report generated by <strong><%= email %></strong> on <i><%= new Date().toLocaleDateString() %></i>
            </p>
        </div>
        
    </div>
</section>