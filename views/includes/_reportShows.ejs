<section class="section">
    <div class="container">
        <div class="level">
            <div class="level-left">
                <h1 class="title">
                    <% if (typeof user !== 'undefined' && user) { %>
                        AI Report for <%= user.full_name || user.email %>
                    <% } else { %>
                        AI Report
                    <% } %>
                </h1>
            </div>
            <div class="level-right">
                <a href="/users/list" class="button is-light">Back to Users</a>
            </div>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
        <div class="notification is-danger is-light">
            <button class="delete" onclick="this.parentElement.remove()"></button>
            <strong><i class="fas fa-exclamation-triangle"></i> Error:</strong> <%= error %>
        </div>
        <% } %>

        <% if (!(typeof report !== 'undefined' && report)) { %>
        <div class="box">
            <h2 class="subtitle">Select Report Period</h2>
            <p class="mb-4">Choose a quarter to auto-fill the date range, or set the dates manually using the calendars. If a quarter is selected and you change a date, the quarter will be deselected automatically.</p>
            <form id="report-form" action="/users/report/<%= user.user_id %>" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="report_type" id="report-type-input" value="<%= (typeof reportType !== 'undefined' ? reportType : '') %>">

                <!-- Quarter buttons + date inputs in one row -->
                <div class="columns is-vcentered">
                    <div class="column">
                        <label class="label">Quarter</label>
                        <div class="buttons" id="quarter-buttons">
                            <%
                                var now = new Date();
                                var currentQuarter = Math.floor(now.getMonth() / 3) + 1;
                                var currentYear = now.getFullYear();
                                var quarterLabels = ['Jan – Mar', 'Apr – Jun', 'Jul – Sep', 'Oct – Dec'];
                                var quarters = [];
                                var q = currentQuarter - 1;
                                var y = currentYear;
                                if (q < 1) { q = 4; y--; }
                                for (var i = 0; i < 4; i++) {
                                    quarters.unshift({ year: y, quarter: q, label: 'Q' + q + ' ' + y + ' (' + quarterLabels[q - 1] + ')' });
                                    q--;
                                    if (q < 1) { q = 4; y--; }
                                }
                            %>
                            <% quarters.forEach(function(qtr) { %>
                                <button type="button"
                                    class="button is-outlined quarter-btn"
                                    data-quarter="<%= qtr.year %>-Q<%= qtr.quarter %>"
                                    data-year="<%= qtr.year %>"
                                    data-q="<%= qtr.quarter %>">
                                    <%= qtr.label %>
                                </button>
                            <% }); %>
                        </div>
                    </div>
                    <div class="column is-narrow">
                        <div class="field is-grouped">
                            <div class="control">
                                <label class="label is-small">Start Date</label>
                                <input class="input" type="date" name="start_date" id="start-date"
                                    value="<%= (typeof startDate !== 'undefined' && startDate) ? startDate : '' %>">
                            </div>
                            <div class="control">
                                <label class="label is-small">End Date</label>
                                <input class="input" type="date" name="end_date" id="end-date"
                                    value="<%= (typeof endDate !== 'undefined' && endDate) ? endDate : '' %>">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="field mt-4">
                    <div class="control">
                        <button type="submit" class="button is-primary" id="submit-btn">
                            <span class="icon"><i class="fas fa-file-alt"></i></span>
                            <span>Generate Report</span>
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <style>
            .quarter-btn {
                color: #000 !important;
            }
            .quarter-btn.is-selected {
                background-color: #ffe08a !important;
                border-color: #ffd257 !important;
                color: #000 !important;
            }
        </style>

        <script>
        (function() {
            var activeQuarter = null;
            var startInput = document.getElementById('start-date');
            var endInput = document.getElementById('end-date');
            var reportTypeInput = document.getElementById('report-type-input');
            var quarterBtns = document.querySelectorAll('.quarter-btn');

            function pad(n) { return n < 10 ? '0' + n : '' + n; }

            function formatDate(d) {
                return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate());
            }

            function getQuarterDates(year, q) {
                var startMonth = (q - 1) * 3;
                var start = new Date(year, startMonth, 1);
                var end = new Date(year, startMonth + 3, 0);
                return { start: start, end: end };
            }

            function deselectAll() {
                quarterBtns.forEach(function(b) {
                    b.classList.remove('is-selected');
                    b.classList.add('is-outlined');
                });
                activeQuarter = null;
            }

            quarterBtns.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var key = btn.getAttribute('data-quarter');
                    var year = parseInt(btn.getAttribute('data-year'));
                    var q = parseInt(btn.getAttribute('data-q'));

                    if (activeQuarter === key) {
                        deselectAll();
                        startInput.value = '';
                        endInput.value = '';
                        reportTypeInput.value = '';
                    } else {
                        deselectAll();
                        activeQuarter = key;
                        btn.classList.add('is-selected');
                        btn.classList.remove('is-outlined');

                        var dates = getQuarterDates(year, q);
                        startInput.value = formatDate(dates.start);
                        endInput.value = formatDate(dates.end);
                        reportTypeInput.value = key;
                    }
                });
            });

            // Manual date change deselects any active quarter
            function onManualDateChange() {
                deselectAll();
                reportTypeInput.value = 'custom';
            }
            startInput.addEventListener('input', onManualDateChange);
            endInput.addEventListener('input', onManualDateChange);

            // Client-side validation
            document.getElementById('report-form').addEventListener('submit', function(e) {
                var startVal = startInput.value;
                var endVal = endInput.value;

                if (!startVal || !endVal) {
                    e.preventDefault();
                    alert('Please select a quarter or enter a date range.');
                    return;
                }

                var sDate = new Date(startVal + 'T00:00:00');
                var eDate = new Date(endVal + 'T00:00:00');
                if (sDate > eDate) {
                    e.preventDefault();
                    alert('Start date cannot be after end date.');
                    return;
                }

                if (!reportTypeInput.value) {
                    reportTypeInput.value = 'custom';
                }
            });
        })();
        </script>
        <% } %>

        <% if (typeof report !== 'undefined' && report) { %>
        <div class="box">
            <div class="level mb-2">
                <div class="level-left">
                    <h2 class="subtitle mb-0">Report Results</h2>
                </div>
                <div class="level-right">
                    <span class="tag is-info is-light is-medium">
                        <%= (typeof startDate !== 'undefined' ? startDate : '') %> &mdash; <%= (typeof endDate !== 'undefined' ? endDate : '') %>
                    </span>
                </div>
            </div>
            <div class="content">
                <%- report.replace(/\n/g, '<br>') %>
            </div>
        </div>

        <div class="content has-text-right mt-2">
            <p class="is-size-6 has-text-grey">
                Report generated by <strong><%= email %></strong> on <i><%= new Date().toLocaleDateString() %></i>
            </p>
        </div>

        <div class="field mt-4">
            <a href="/users/report/<%= user.user_id %>" class="button is-light">
                <span class="icon"><i class="fas fa-arrow-left"></i></span>
                <span>Generate Another Report</span>
            </a>
        </div>
        <% } %>

    </div>
</section>