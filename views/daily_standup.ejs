<%- include('includes/_header') %>

<section class="section">
    <div class="container">
        <h1 class="title">Register Daily Activity</h1>
        <h2 class="subtitle">Complete your standup for today</h2>
    </div>
    <div class="level-right">
		<a href="/daily_standup/history" class="button is-light"><strong>← Back</strong></a>
	</div>
</section>

<section class="section" style="padding-top: 0;">
    <div class="container">
        <div class="columns is-centered">
            <div class="column is-half">

                <% if (error && error.length > 0) { %>
                    <div class="notification is-danger is-light">
                        <button class="delete" onclick="this.parentElement.remove()"></button>
                        <%= error %>
                    </div>
                <% } %>

                <% if (success && success.length > 0) { %>
                    <div class="notification is-success is-light">
                        <button class="delete" onclick="this.parentElement.remove()"></button>
                        <%= success %>
                    </div>
                <% } %>

                <div class="box">
                    <form action="<%= editMode ? '/daily_standup/edit/' + standup.standup_id : '/daily_standup' %>" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                        <div class="field">
                            <label class="label">
                                What did you do today?
                                <span class="has-text-danger">*</span>
                            </label>
                            <div class="control">
                                <textarea
                                    class="textarea"
                                    name="did_today"
                                    placeholder="Describe the tasks you completed today..."
                                    rows="4"
                                    required
                                    ><%= editMode ? standup.did_today : '' %></textarea>
                            </div>
                        </div>

                        <div class="field">
                            <label class="label">
                                What will you do tomorrow?
                                <span class="has-text-danger">*</span>
                            </label>
                            <div class="control">
                                <textarea
                                    class="textarea"
                                    name="do_tomorrow"
                                    placeholder="Describe the tasks you plan to do tomorrow..."
                                    rows="4"
                                    required
                                    ><%= editMode ? standup.do_tomorrow : '' %></textarea>
                            </div>
                        </div>

                        <div class="field">
                            <label class="label">Blockers</label>
                            <div class="control">
                                <textarea
                                    class="textarea"
                                    name="blockers"
                                    placeholder="Do you have any blockers or impediments? (optional)"
                                    rows="3"
                                    ><%= editMode ? (standup.blockers || '') : '' %></textarea>
                            </div>
                            <p class="help">This field is optional.</p>
                        </div>

                        <div class="field">
                            <label class="label">Date</label>
                            <div class="control">
                                <input
                                    class="input"
                                    type="date"
                                    name="date"
                                    id="fecha_blocker"
                                    value="<%= editMode ? standup.date.toISOString().split('T')[0] : new Date().toLocaleDateString('en-CA') %>"
                                >
                            </div>
                        </div>

                        <div class="field">
                            <div class="control">
                                <button type="submit" class="button is-primary is-fullwidth">
                                    <%= editMode ? 'Save Changes' : 'Submit' %>
                                </button>
                                <div class="has-text-centered mt-3">
                                    <a href="/daily_standup/history" class="button is-small is-danger is-outlined">Cancel</a>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>

                <p class="has-text-grey has-text-centered is-size-7">
                    You can only register one activity per day. Fields marked with
                    <span class="has-text-danger">*</span> are required.
                </p>

            </div>
        </div>
    </div>
</section>

<%- include('includes/_footer') %>
