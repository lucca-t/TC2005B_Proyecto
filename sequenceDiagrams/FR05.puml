@startuml
skinparam style strictuml
skinparam maxmessagesize 150

actor Admin as U
boundary "Routes" as RO
boundary "View: userAdd.ejs" as VA
boundary "View: userList.ejs" as VL
control "users.controller" as C
entity "User.model" as UM
database "MySQL" as BD

activate U
U -> VA: Click Add User
deactivate U

activate VA
VA -> RO: GET /users/add
deactivate VA

activate RO
RO -> C: get_add(request, response, next)
deactivate RO

activate C
C -> VA: render('userAdd', {csrfToken, email, formData})
deactivate C

activate VA
VA -> U: HTML add-user form
deactivate VA

activate U
U -> VA: Fill form and submit
deactivate U

activate VA
VA -> RO: POST /users/add
deactivate VA

activate RO
RO -> C: post_add(request, response, next)
deactivate RO

activate C
C -> C: normalize email, password, full_name, slack_handle, slack_id
C -> C: build formData

alt Missing required fields
    C -> VA: status(400).render('userAdd', {error: 'All fields are required.'})
    deactivate C

    activate VA
    VA -> U: Form with required-fields error
    deactivate VA
else Email format invalid
    C -> VA: status(400).render('userAdd', {error: 'Email format is invalid. Please use a valid email address.'})
    deactivate C

    activate VA
    VA -> U: Form with invalid-email error
    deactivate VA
else Slack handle invalid
    C -> VA: status(400).render('userAdd', {error: 'Slack handle is invalid. Use letters, numbers, dot, dash, or underscore.'})
    deactivate C

    activate VA
    VA -> U: Form with invalid-slack error
    deactivate VA
else Field length exceeds limit
    C -> VA: status(400).render('userAdd', {error: 'One or more fields are too long. Please review the form and try again.'})
    deactivate C

    activate VA
    VA -> U: Form with max-length error
    deactivate VA
else Valid input
    C ->> UM: save(user)
    activate UM

    UM -> UM: bcrypt.hash(password, 12)
    UM ->> BD: INSERT INTO user(email, password, full_name, slack_handle, slack_id) VALUES (?, ?, ?, ?, ?)
    activate BD
    BD -->> UM: insertResult(insertId)
    deactivate BD

    UM ->> BD: INSERT INTO user_role (user_id, role_id, start_date) SELECT ?, role_id, CURRENT_TIMESTAMP(6) FROM role WHERE role_name = 'Member' LIMIT 1
    activate BD
    BD -->> UM: result
    deactivate BD

    UM -->> C: save completed
    deactivate UM

    C -> VL: redirect('/users/list') + session.success
    deactivate C

    activate VL
    VL -> RO: GET /users/list
    deactivate VL

    activate RO
    RO -> C: get_list(request, response, next)
    deactivate RO

    activate C
    C ->> UM: getAllWithRoles()
    activate UM
    UM ->> BD: SELECT u.user_id, u.email, u.full_name, u.slack_handle, u.slack_id, r.role_name, (SELECT COUNT(DISTINCT MONTH(rp.date_generated)) FROM report rp JOIN user_report urp ON rp.report_id = urp.report_id WHERE urp.user_about = u.user_id AND QUARTER(rp.date_generated) = QUARTER(NOW()) AND YEAR(rp.date_generated) = YEAR(NOW()) AND rp.deleted_at IS NULL) AS quarterProgress FROM user u LEFT JOIN user_role ur ON u.user_id = ur.user_id AND ur.end_date IS NULL LEFT JOIN role r ON ur.role_id = r.role_id WHERE u.deleted_at IS NULL
    activate BD
    BD -->> UM: rows
    deactivate BD
    UM -->> C: rows
    deactivate UM

    C -> VL: render('userList', {users, success: 'User registered successfully!'})
    deactivate C

    activate VL
    VL -> U: HTML + success notification + user list
    deactivate VL
end

@enduml