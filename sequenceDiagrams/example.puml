@startuml
skinparam style strictuml

actor Lead as U
boundary "routes" as RO
boundary "vista teamNew.ejs" as V
control "team.controller" as C
entity "Team.model" as TM
database "unitas_system" as BD

activate U
U -> RO: GET /teams/new
deactivate U

activate RO
RO -> C: getNew(request, response)
deactivate RO

activate C
C -> V: response.render('teams/new.ejs')
deactivate C

activate V
V -> U: HTML form
deactivate V


activate U
U -> RO: POST /teams
deactivate U

activate RO
RO -> C: create(request, response)
deactivate RO

activate C
C -> C: validate(request.body)

alt Invalid input (missing/invalid)
    C -> V: response.render('teams/new.ejs', {errors})
    deactivate C

    activate V
    V -> U: HTML + Error messages
    deactivate V

else Valid input
    C -> TM: findByName(name)
    activate TM

    TM -> BD: SELECT * FROM team WHERE name=?
    activate BD
    BD --> TM: exists/null
    deactivate BD

    TM --> C: exists/null
    deactivate TM

    alt Name exists
        C -> V: response.render('teams/new.ejs', {error: "Team already exists"})
        deactivate C

        activate V
        V -> U: HTML + Error message
        deactivate V

    else New team
        C -> C: generate team_id
        C -> C: set status, created_at

        C -> TM: insert({team_id, name, description, status, created_at})
        activate TM

        TM -> BD: INSERT INTO team (team_id, name, description, status, created_at)\nVALUES (?, ?, ?, ?, ?)
        activate BD

        alt Insert success
            BD -> BD: Store new Team record
            BD --> TM: team_id
            deactivate BD

            TM --> C: team_id
            deactivate TM

            C -> V: response.render('teams/show.ejs', {team: team_id, success: "Team created successfully"})
            deactivate C

            activate V
            V -> U: HTML + Success message
            deactivate V

        else Insert fail
            BD --> TM: error
            deactivate BD

            TM --> C: error
            deactivate TM

            C -> V: response.render('teams/new.ejs', {msg: "could not save"})
            deactivate C

            activate V
            V -> U: HTML + Error message
            deactivate V
        end
    end
end

@enduml