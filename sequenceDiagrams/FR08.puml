@startuml
skinparam style strictuml
skinparam maxmessagesize 150

actor Lead as U
boundary "Routes" as RO
boundary "View: userEdit.ejs" as V
control "users.controller" as C
entity "users.model" as UM
database "MySQL" as BD


U -> RO: GET /users/edit/:email
deactivate U

activate RO
RO -> C: get_edit(request, response)
deactivate RO

activate C
C ->> UM: fetchOne(params.email)
activate UM

UM ->> BD: SELECT * FROM User\nWHERE email = ?
activate BD
BD -->> UM: rows / error
deactivate BD

alt fetchOne success
    UM -->> C: rows
    deactivate UM

    C -> V: render('userEdit', {user: rows[0], csrfToken, email: session.email})
    deactivate C

    activate V
    V -> U: HTML edit form
    activate U
    deactivate U
    deactivate V
else fetchOne error
    
    activate UM
    UM -->> C: error
    deactivate UM

    C -> RO: next(error)
    deactivate C
    RO -> U: Error response
    activate U
    deactivate U
end


U -> RO: POST /users/edit/:email
deactivate U

activate RO
RO -> C: post_edit(request, response)
deactivate RO

activate C
C -> C: normalize email, full_name, slack_handle, slack_id

alt Some field is empty/null
    C -> C: build user payload from normalized fields
    C -> V: status(400).render('userEdit', {error: 'All fields are required. None can be empty.'})
    deactivate C

    activate V
    V -> U: HTML + validation error
    activate U
    deactivate U
    deactivate V

else Email format invalid
    activate C
    C -> C: build user payload from normalized fields
    C -> V: status(400).render('userEdit', {error: 'Email format is invalid. Please use a valid email address.'})
    deactivate C

    activate V
    V -> U: HTML + validation error
    activate U
    deactivate U
    deactivate V

else Valid data
    activate C
    C ->> UM: updateWithoutPassword(originalEmail, normalizedEmail, normalizedFullName, normalizedSlackHandle, normalizedSlackId)
    activate UM

    UM ->> BD: UPDATE User\nSET email=?, full_name=?, slack_handle=?, slack_id=?\nWHERE email=?
    activate BD
    BD -->> UM: ok / error
    deactivate BD

    alt update success
        UM -->> C: ok
        deactivate UM

        C -> RO: response.redirect('/users/list')
        deactivate C
        RO -> U: 302 Redirect to /users/list
        activate U
        deactivate U
    else update error
        activate UM
        UM -->> C: error
        deactivate UM
        activate C
        C -> C: console.error('[POST /users/edit] Failed to update user: ...')
        C -> C: build user payload from normalized fields
        C -> V: status(400).render('userEdit', {error: 'Error updating user: ...'})
        deactivate C

        activate V
        V -> U: HTML + DB error message
        activate U
        deactivate U
        deactivate V
    end
end

@enduml