@startuml
skinparam style strictuml
skinparam maxmessagesize 150

actor Lead as U
boundary "Routes" as RO
boundary "View: projectsAdd.ejs" as VA
boundary "View: projectShow.ejs" as VS
control "projects.controller" as C
entity "Project.model" as PM
database "MySQL" as BD

activate U
U -> RO: GET /projects/add
deactivate U

activate RO
RO -> C: get_add(request, response, next)
deactivate RO

activate C
C ->> PM: getTeams()
activate PM

PM ->> BD: SELECT team_id, team_name\nFROM Team\nWHERE deleted_at IS NULL\nORDER BY team_name ASC
activate BD

BD -->> PM: rows
deactivate BD

PM -->> C: rows
deactivate PM

C -> VA: render('projectsAdd', {csrfToken, email, teams, formData, errors, error, msg})
deactivate C

activate VA
VA -> U: HTML form
deactivate VA

activate U
U -> RO: POST /projects/add
deactivate U

activate RO
RO -> C: post_add(request, response, next)
deactivate RO

activate C
C -> C: normalize name, description, team_id, status
C -> C: build formData

alt Missing required fields
    C ->> PM: getTeams()
    activate PM

    PM ->> BD: SELECT team_id, team_name ...
    activate BD
    BD -->> PM: teams
    deactivate BD

    PM -->> C: teams
    deactivate PM

    C -> VA: status(400).render('projectsAdd', {errors: 'Missing required fields.'})
    deactivate C
    activate VA

    VA -> U: HTML + validation error + preserved formData
    activate U
    deactivate VA
    deactivate U
else Valid input structure
    
    activate C
    C ->> PM: findByNameAndTeam(name, team_id)
    
    activate PM

    PM ->> BD: SELECT project_id\nFROM Project\nWHERE LOWER(name)=LOWER(?) AND team_id=?\nLIMIT 1
    activate BD
    BD -->> PM: existingRows
    deactivate BD

    PM -->> C: existingRows
    deactivate PM

    alt Duplicate project found
        C ->> PM: getTeams()
        activate PM

        PM ->> BD: SELECT team_id, team_name ...
        activate BD
        BD -->> PM: teams
        deactivate BD

        PM -->> C: teams
        deactivate PM

        C -> VA: status(400).render('projectsAdd', {error: 'A project with this name already exists...'})
        deactivate C
        activate VA
        VA -> U: HTML + duplicate error + preserved formData
        activate U
        deactivate U
        deactivate VA

    else New project
        activate C
        C ->> PM: insert({name, description, team_id, status, created_at})
        activate PM

        PM ->> BD: INSERT INTO Project(...) VALUES (...)
        activate BD
        BD -->> PM: insertResult(insertId)
        deactivate BD

        PM ->> BD: SELECT * FROM Project WHERE project_id=? LIMIT 1
        activate BD
        BD -->> PM: inserted row
        deactivate BD

        PM -->> C: insertedProject
        deactivate PM

        C -> VS: render('projectShow', {project: insertedProject, success: 'Project created.'})

        activate VS
        VS -> U: HTML + success message + project details
        activate U
        deactivate U
        deactivate VS
    end

else Unexpected Server Error (Catch block)
    activate C
    C -> C: console.error('[POST /projects/add] ...')
    C ->> PM: getTeams() via renderForm()
    activate PM

    PM ->> BD: SELECT team_id, team_name ...
    activate BD
    BD -->> PM: teams
    deactivate BD

    PM -->> C: teams
    deactivate PM

    C -> VA: status(400).render('projectsAdd', {msg: 'Could not save the project.'})
    deactivate C

    activate VA
    VA -> U: HTML + warning message + preserved formData
    activate U
    deactivate U
    deactivate VA
end

@enduml